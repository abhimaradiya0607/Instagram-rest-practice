<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Post</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .buttonspace {
            padding-top: 30px;
        }
    </style>
</head>

<body>
    <h1>Create a New post:</h1>
    <form method="post" action="/posts">
        <div class="input-group mb-3">
            <span class="input-group-text" id="basic-addon1">@</span>
            <input required type="text" class="form-control" placeholder="Username" name="username"
                aria-label="Username" aria-describedby="basic-addon1">
        </div>
        <div class="mb-3">
            <label for="basic-url" class="form-label">Give Image URL</label>
            <div class="input-group">
                <span class="input-group-text" id="basic-addon3">https://picsum.photos/id/YOUR_CHOICE_ID(EX:1..35..)/400/300</span>
                <input required name="imageUrl" type="text" class="form-control" id="basic-url"
                    placeholder="Copy same as on the left side" aria-describedby="basic-addon3 basic-addon4">
            </div>
        </div>
        <div class="input-group">
            <span class="input-group-text">Enter Your Caption</span>
            <textarea name="caption" class="form-control" aria-label="With textarea"></textarea>
        </div>
        <div class="buttonspace">
            <button type="submit" class="btn btn-success">Share Post</button>
        </div>
    </form>
</body>

</html>