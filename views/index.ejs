<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Feed</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
        <style>
    .mainbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 20px;
        flex-wrap: wrap; /* important */
    }

    .mainbar h1 {
        color: red;
        font-size: 2rem;
        margin: 0;
    }

    .mainbar button {
        background-color: antiquewhite;
        border: 1px solid black;
        border-radius: 5px;
        padding: 8px 12px;
        cursor: pointer;
    }

    .mainfeed {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 20px;
        padding: 10px;
    }
    .postmain {
        width: 100%;
        max-width: 400px;
    }
</style>
</head>
<body>
    <div class="container-fluid">
        <div class="mainbar">
            <h1>Instagram</h1>
            <form method="get" action="/posts/new">
                <button class="btn btn-warning">+ New Post</button>
            </form>
        </div>
    </div>
    <hr>
    <div class="mainfeed">
    <%for (let post of posts) {%>
        <div class="postmain">
            <div class="card border-success mb-3" style="max-width: 400px;">
                <h5 class="card-title">@<%=post.username%></h5>  <p class="card-text"><small class="text-body-secondary">Your id: <%= post.id %> </small></p>
            <div class="card" style="width: 400px;">
                <img src="<%=post.imageUrl%>" class="card-img-top" alt="imageposted<%=post.username%>">
                <div class="card-body">
                <p class="card-text"><%=post.caption%></p>
                <p class="card-text">❤️<%= post.likes%>&nbsp;&nbsp;&nbsp;Verified</p>
                <div class="card-footer bg-transparent border-success" style="max-width: 1000px;">
                    <a href="/posts/<%=post.id%>" class="btn btn-primary">View</a>
                    <a href="/posts/<%=post.id%>/edit" class="btn btn-secondary">Edit</a>
                    <div style="padding: 10px;">
                    <form method="post" action="/posts/<%= post.id%>?_method=DELETE">
                        <button type="submit" class="btn btn-danger">Delete Post</button>
                    </form>
                </div>
                </div>
                </div>
            </div>
        </div>
    </div>
    <%}%>
</div>
</body>
</html>