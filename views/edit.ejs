<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Post</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <h3>
        Edit For username: 
        <span style="color:red;"><%= post.username %></span>
    </h3>
    <form method="post" action="/posts/<%= post.id%>?_method=PATCH">
    <div class="mb-3">
        <label for="basic-url" class="form-label">Edit Image ID:</label>
        <div class="input-group">
            <span class="input-group-text" id="basic-addon3">Change Id to another</span>
            <input value="<%= post.imageUrl.split('/')[4] %>" required  name="imageId" type="text" class="form-control" id="basic-url"
                aria-describedby="basic-addon3 basic-addon4">
        </input>
        </div>
        <div class="input-group">
            <span class="input-group-text">Edit The Caption:</span>
            <textarea name="caption" class="form-control" aria-label="With textarea"><%= post.caption %> </textarea>
        </div>
        <div class="buttonspace">
            <button type="submit" class="btn btn-success">Confirm Update</button>
        </div>
    </form>
</body>
</html>